{
    "editor.fontFamily": "BlexMono Nerd Font", // Шрифт редактора (Nerd Font = поддержка иконок и спецсимволов)
    "editor.fontSize": 17, // Размер шрифта
    "editor.cursorBlinking": "solid", // Курсор не мигает

    "files.autoSave": "afterDelay", // Автосохранение
    "files.insertFinalNewline": true, // Новая строка в конце файла
    "files.associations": {},

    "files.exclude": {
        "/.DS_Store": true,
        "/node_modules": true,
        "/bower_components": true,
        "/pycache": true,
        "/.cache": true,
        "/.idea": true,
        "/.pytest_cache": true,
        "/.mypy_cache": true,
        "/.venv": true,
        "/.coverage": true,
        "/*.py[co]": true,
        "/htmlcoverage": true,
        "**/docs/build": true
    },

    "explorer.confirmDragAndDrop": true, // Подтверждение перемещения файлов
    "explorer.confirmDelete": false, // Удаление без подтверждения

    "window.zoomLevel": 1, // Масштаб интерфейса
    "window.newWindowDimensions": "maximized", // Окно на весь экран

    "workbench.startupEditor": "none", // Без стартового экрана
    "workbench.statusBar.visible": false, // Скрыть статус-бар
    "workbench.tips.enabled": false, // Отключить подсказки

    "workbench.activityBar.location": "hidden", // Полностью скрывает левую панель (Explorer, Git, Extensions)
    "workbench.sideBar.location": "right", // Перемещает боковую панель вправо

    "workbench.editor.showIcons": false, // Убирает иконки файлов во вкладках (ещё больше минимализма)
    "workbench.editor.labelFormat": "medium", // Формат имени файла
    "workbench.editor.empty.hint": "hidden", // Скрыть подсказку пустого редактора

    "breadcrumbs.enabled": false, // Убирает верхнюю навигацию по пути файла (breadcrumbs)

    "workbench.colorTheme": "Moegi Space", // Тема

    "workbench.editor.showTabs": "single", // Одна вкладка

    "git.enableSmartCommit": true, // Commit без staging
    "git.autofetch": false, // Не авто-fetch
    "git.autorefresh": true, // Автообновление статуса

    "update.mode": "none", // Отключить обновления
    "extensions.ignoreRecommendations": true, // Игнорировать рекомендации

    "redhat.telemetry.enabled": false, // Отключить телеметрию
    "security.workspace.trust.untrustedFiles": "prompt", // Запрос доверия

    "diffEditor.ignoreTrimWhitespace": true, // Игнорировать пробелы в diff

    "editor.dragAndDrop": false, // Отключить drag & drop
    "editor.minimap.enabled": false, // Отключить minimap
    "editor.scrollBeyondLastLine": false // Без пустого пространства внизу
}