[core]
    pager = delta
    
[status]
    branch = true
    short = true
    showStash = true
    showUntrackedFiles = no

[interactive]
    diffFilter = delta --color-only
    
[delta]
    navigate = true  
    dark = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Catppuccin Mocha
    
[merge]
    conflictstyle = zdiff3
    
[alias]
    l = log --graph --topo-order --all --pretty=format:'%w(100,0,6)%C(yellow)%h%Creset%C(bold)%C(red)%d %C(cyan)%ar %C(green)%an%n%C(bold)%C(white)%s %N' --abbrev-commit
    cm = commit -m
    s = status

[credential]
    helper = cache --timeout=3600
